FLASK_ENV=development
SECRET_KEY=change-me-before-production
# Leave empty to use instance/save_us.sqlite3.
DATABASE_URL=

# Optional live AI analysis. Without this value, SAVE-US uses its deterministic demo fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
# Optional override for the visual safety review of road-accident media.
OPENAI_MEDIA_MODEL=gpt-5.6
